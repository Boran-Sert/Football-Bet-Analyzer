# ═══════════════════════════════════════════════
#  Football SaaS — Ortam Değişkenleri Şablonu
#  Kopyalayın: cp .env.example .env
#  Kendi değerlerinizle doldurun.
# ═══════════════════════════════════════════════

# ── Database ──
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_TLS_SKIP_VERIFY=False
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME

REDIS_URL=redis://localhost:6379

# ── External APIs ──
ODDS_API_KEY=YOUR_ODDS_API_KEY_HERE
FOOTBALL_DATA_API_KEY=YOUR_FOOTBALL_DATA_API_KEY_HERE

# ── JWT (Güvenli random key üretin: python -c "import secrets; print(secrets.token_hex(32))") ──
JWT_SECRET_KEY=CHANGE_ME_TO_A_64_CHAR_HEX_STRING

# ── Email (Resend) ──
RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE
EMAIL_FROM_ADDRESS=Sports Analyzer <noreply@yourdomain.com>
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# ── Payment: Iyzico ──
PAYMENT_PROVIDER=iyzico
IYZICO_API_KEY=YOUR_IYZICO_API_KEY_HERE
IYZICO_SECRET_KEY=YOUR_IYZICO_SECRET_KEY_HERE

# ── Payment: Stripe (alternatif) ──
# PAYMENT_PROVIDER=stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_ELITE=

# ── Telegram Alerting ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Environment ──
ENVIRONMENT=development
REQUIRE_EMAIL_VERIFICATION=False
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_PROXIES=127.0.0.1
